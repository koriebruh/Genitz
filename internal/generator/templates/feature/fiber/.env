# ────────────────────────────────────────────
#   FIBER APP CONFIG
# ────────────────────────────────────────────
BODY_LIMIT_MB=4
READ_TIMEOUT=10s
WRITE_TIMEOUT=10s
IDLE_TIMEOUT=120s

# Proxy isi kalau di belakang nginx / cloudflare / load balancer
# kosongkan kalau expose langsung
PROXY_HEADER=X-Forwarded-For
TRUST_PROXY=false